# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / OS debris
.vscode/
.idea/
Thumbs.db

# runtime data (user uploads, auth store, scheduler state)
.data/
/public/uploads/
/public/voiceovers/
/public/ai-images/
/public/music/

# Claude-Code-as-backend bridge file queue
.ai-bridge/

# Capacitor — platform dirs are regenerable via `bun run cap:add:<platform>`
/ios/
/android/
.capacitor/

# Eval harness — case fixtures (78MB Isaac Pack), results, generated cases
/eval/fixtures/isaac-pack/
/eval/fixtures/reference_transcript_clean.txt
/eval/results/
/eval/cases/generated/
/eval/iterate/experiment-log.jsonl
