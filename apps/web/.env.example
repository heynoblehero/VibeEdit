# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hyperframes_web

# Auth
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Render mode: "local" runs producer in-process; "docker" uses hyperframes-render image
RENDER_MODE=local
MAX_CONCURRENT_RENDERS=2

# Storage root (absolute)
STORAGE_ROOT=
