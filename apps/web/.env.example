# Database
# Set DATABASE_URL to use Postgres (Neon recommended for production).
# Run: bun add @neondatabase/serverless drizzle-orm  then  bun run db:migrate
# Leave unset to use SQLite at storage/app.db (local dev only).
DATABASE_URL=postgres://user:pass@your-neon-host.neon.tech/dbname

# Auth
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000
# Public base URL — used in emails, admin deep-links, verification links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Admin console + operational alerts ───────────────────────────────────────
# Comma-separated admin emails. Gates /admin AND receives the new-signup,
# paid-trial, and support-message notification emails.
ADMIN_EMAILS=you@example.com
# Password seeded for the admin credential account on boot (reset every start).
ADMIN_PASSWORD=

# ── Secrets encryption ───────────────────────────────────────────────────────
# AES-256-GCM key that encrypts pooled provider credentials + BYOK keys at rest.
# Set before adding any credential in the admin console; rotating it makes
# previously stored secrets undecryptable.
API_KEYS_SECRET=replace-me-with-openssl-rand-hex-32

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Without RESEND_API_KEY every mail (user + admin alerts) just logs to console.
RESEND_API_KEY=
EMAIL_FROM=VibeEdit Video <noreply@vibeedit.video>

# ── AI providers ─────────────────────────────────────────────────────────────
# In production, prefer adding these from the admin Providers console (/admin →
# Providers), which pools + rotates credentials. Env vars are the fallback the
# pool uses when it has no managed credential for a provider.
#
# OFFICIAL (plain API keys):
ANTHROPIC_API_KEY=sk-ant-...
# Optional reverse proxy in front of the Anthropic API (brain + vision).
ANTHROPIC_BASE_URL=
# xAI Grok 2 (official brain option).
XAI_API_KEY=
# Replicate token — FLUX, Ideogram, Kling, Luma, Riffusion ALL run through this
# single token. Do NOT add separate luma/kling keys; they are Replicate-hosted.
REPLICATE_API_TOKEN=
# Official video vendors with their own REST APIs.
RUNWAY_API_KEY=
PIKA_API_KEY=
LUMA_API_KEY=
KLING_API_KEY=
#
# UNOFFICIAL (self-hosted proxies — ToS risk; each needs YOUR proxy URL + token):
# Midjourney (novelzk/midjourney-proxy shape).
MIDJOURNEY_PROXY_URL=
MIDJOURNEY_PROXY_KEY=
# Suno / Udio (gcui-art/suno-api shape; account cookie as the secret).
SUNO_PROXY_URL=
SUNO_COOKIE=
UDIO_PROXY_URL=
UDIO_COOKIE=
# Viggle (character animation / pose transfer).
VIGGLE_PROXY_URL=
VIGGLE_TOKEN=
# Grok via the archived grok2api relay (brain fallback).
GROK2API_URL=
GROK2API_KEY=

# Render mode: "local" runs producer in-process; "docker" uses hyperframes-render image
RENDER_MODE=local
MAX_CONCURRENT_RENDERS=2

# Storage root (absolute path). Defaults to ./storage/ if unset.
STORAGE_ROOT=

# Import from URL (yt-dlp). YT_DLP_PATH overrides the binary location (default
# "yt-dlp" on PATH; the Docker image installs it at /usr/local/bin/yt-dlp).
# IMPORT_MAX_DURATION_SEC caps how long a source video may be (default 900 = 15m).
YT_DLP_PATH=
IMPORT_MAX_DURATION_SEC=900
# YouTube blocks automated downloads from datacenter IPs ("Sign in to confirm
# you're not a bot"). To make imports work from a cloud server, set ONE of:
#   YTDLP_COOKIES_FILE — path to a cookies.txt exported from a logged-in YouTube
#                        account (reliable; cookies expire, refresh periodically).
#   YTDLP_PROXY        — a residential/rotating proxy URL, e.g. http://user:pass@host:port
# Optionally force player clients, e.g. "tv,web_safari,android".
YTDLP_COOKIES_FILE=
YTDLP_PROXY=
YTDLP_PLAYER_CLIENTS=

# Billing — Polar.sh (primary)
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_PRODUCT_CREATOR=
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_STUDIO=
# Webhook signing secret — /api/webhooks/polar returns 500 until this is set.
POLAR_WEBHOOK_SECRET=
# Set to "true" to actually enforce plan limits / paywall.
BILLING_ENFORCE=false

# Social publishing (required for YouTube/TikTok publishing feature)
PUBLISH_TOKEN_SECRET=replace-me-with-32-char-secret

# Optional: ElevenLabs for TTS voiceovers
ELEVENLABS_API_KEY=

# Optional: Pexels for stock footage search
PEXELS_API_KEY=

# Optional: FAL for AI b-roll generation
FAL_KEY=

# Observability — Sentry (error tracking). Leave SENTRY_DSN unset to disable
# (dev no-ops, no network traffic). NEXT_PUBLIC_SENTRY_DSN enables browser-side
# capture. The SENTRY_ORG/PROJECT/AUTH_TOKEN trio is only needed at build time
# for source-map upload and can stay empty in dev.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# SENTRY_TRACES_SAMPLE_RATE=0

# Observability — PostHog (product analytics / funnel). Leave the key unset to
# disable (client + server both no-op). The same project key is used on the
# server and the browser; HOST defaults to https://us.i.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Admin observability READ access (admin "Monitoring" tile) ────────────────
# These power the /admin Monitoring tab. They are separate from the send-side
# DSN / project key above and are ONLY needed to *read* data back. Each tile
# no-ops gracefully (shows a "connect" hint + deep-link button) when its vars
# are unset, so these are optional.

# Sentry REST API read. SENTRY_AUTH_TOKEN must have project:read scope.
# SENTRY_ORG / SENTRY_PROJECT are the org + project *slugs*. Reuses the
# SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN already defined above if set.
# SENTRY_API_URL overrides the REST host for region flexibility — the runtime
# DSN is EU (ingest.de.sentry.io) but the API host stays https://sentry.io
# (set https://de.sentry.io here only if your org requires the regional host).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_API_URL=https://sentry.io

# PostHog Query API (HogQL) read. Needs a PERSONAL API key (not the project
# ingestion key) with query:read scope. POSTHOG_PROJECT_ID defaults to 88526.
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=88526
